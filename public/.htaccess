# cPanel static deploy — upload contents of /out to public_html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # CSS/JS/fonts/images — never rewrite to HTML
  RewriteRule ^_next/ - [L]
  RewriteRule ^(images|icons|fonts|videos)/ - [L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Article detail: /article/123 → article.html
  RewriteRule ^article/[^/]+/?$ /article.html [L]

  # Page routes: /contact → contact.html
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  RewriteRule ^ /404.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header always append X-Frame-Options SAMEORIGIN
  Header always set X-Content-Type-Options nosniff
  Header always set Referrer-Policy "origin-when-cross-origin"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

ErrorDocument 404 /404.html
