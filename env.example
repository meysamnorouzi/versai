# WordPress API Configuration (WordPress installed in /admin)
NEXT_PUBLIC_WORDPRESS_API_URL=https://versai.ir/admin/wp-json/wp/v2
NEXT_PUBLIC_WORDPRESS_SITE_URL=https://versai.ir/admin
NEXT_PUBLIC_WORDPRESS_API_KEY=
NEXT_PUBLIC_WORDPRESS_USERNAME=
NEXT_PUBLIC_WORDPRESS_PASSWORD=

# Versai Custom API
NEXT_PUBLIC_VERSAI_API_URL=https://versai.ir/admin/wp-json/versai/v1

# Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Social Media
NEXT_PUBLIC_FACEBOOK_APP_ID=
NEXT_PUBLIC_TWITTER_HANDLE=@versai_immigration

# App Settings
NEXT_PUBLIC_APP_TITLE=موسسه مهاجرتی ورسای
NEXT_PUBLIC_APP_DESCRIPTION=اقامت تمکن مالی و تحصیلی فرانسه - کانادا

# API Settings
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_API_RETRY_ATTEMPTS=3
NEXT_PUBLIC_CACHE_TIMEOUT=300000

# Debug Settings
NEXT_PUBLIC_DEBUG_MODE=true
NEXT_PUBLIC_LOG_LEVEL=info
